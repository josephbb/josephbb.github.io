---
import '../styles/global.css';
import { getSite, getSocials } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
  /** Absolute or site-root path for social share image. */
  image?: string;
  /** Open Graph type; defaults to website. */
  ogType?: 'website' | 'article';
  /** Optional JSON-LD object(s) embedded in the page head. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const site = getSite();
const socials = getSocials();
const {
  title,
  description = site.tagline,
  image = '/images/prof_pic.jpg',
  ogType = 'website',
  jsonLd,
} = Astro.props;
const pageTitle = title ? `${title} · ${site.short_name}` : site.name;
const pathname = Astro.url.pathname;
const canonicalURL = new URL(pathname, Astro.site);
const imageURL = new URL(image, Astro.site);
const jsonLdBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

const nav = [
  { href: '/', label: 'About' },
  { href: '/news/', label: 'News' },
  { href: '/publications/', label: 'Publications' },
  { href: '/writing/', label: 'Writing' },
  { href: '/cv/', label: 'CV' },
];

function isCurrent(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content={site.name} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:site_name" content={site.short_name} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400;1,6..72,500&family=Source+Sans+3:ital,wght@0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    {
      jsonLdBlocks.map((block) => (
        <script type="application/ld+json" set:html={JSON.stringify(block)} />
      ))
    }
    <script is:inline>
      (function () {
        try {
          var theme = localStorage.getItem('theme');
          if (theme !== 'night' && theme !== 'light') theme = 'light';
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header__inner">
          <a class="site-logo" href="/">{site.short_name}</a>
          <nav class="site-nav" aria-label="Primary">
            {
              nav.map((item) => (
                <a
                  href={item.href}
                  aria-current={isCurrent(item.href) ? 'page' : undefined}
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
          <button
            type="button"
            class="theme-toggle"
            data-theme-toggle
            aria-label="Switch color theme"
          >
            Night
          </button>
        </div>
      </header>

      <main class="site-main">
        <slot />
      </main>

      <footer class="site-footer">
        <p>
          © {new Date().getFullYear()}
          {' '}{site.name}. {site.contact_note}
          {' '}<a href={`mailto:${socials.email}`}>{socials.email}</a>.
        </p>
      </footer>
    </div>
    <script>
      function currentTheme() {
        const attr = document.documentElement.getAttribute('data-theme');
        return attr === 'night' ? 'night' : 'light';
      }

      function applyTheme(theme: 'light' | 'night') {
        document.documentElement.setAttribute('data-theme', theme);
        try {
          localStorage.setItem('theme', theme);
        } catch {
          /* ignore */
        }
        syncToggle();
      }

      function syncToggle() {
        const theme = currentTheme();
        const next = theme === 'night' ? 'light' : 'night';
        document.querySelectorAll('[data-theme-toggle]').forEach((el) => {
          if (!(el instanceof HTMLButtonElement)) return;
          el.textContent = next === 'night' ? 'Night' : 'Day';
          el.setAttribute(
            'aria-label',
            next === 'night' ? 'Switch to night theme' : 'Switch to day theme',
          );
        });
      }

      document.querySelectorAll('[data-theme-toggle]').forEach((el) => {
        el.addEventListener('click', () => {
          applyTheme(currentTheme() === 'night' ? 'light' : 'night');
        });
      });

      syncToggle();
    </script>
  </body>
</html>
