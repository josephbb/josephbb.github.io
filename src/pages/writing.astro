---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate, dateAttr } from '../lib/dates';
import { getEssays } from '../lib/site';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const essays = getEssays();

function outletMark(outlet: string) {
  const words = outlet.trim().split(/\s+/);
  if (words.length === 1) return words[0]!.slice(0, 3).toUpperCase();
  return words
    .map((w) => w[0])
    .join('')
    .slice(0, 3)
    .toUpperCase();
}

function essayDate(iso: string) {
  return new Date(`${iso}T00:00:00.000Z`);
}
---

<BaseLayout
  title="Writing"
  description="Writing for other outlets, as well as notes on collective behavior, statistics, and technology."
>
  <h1 class="page-title">Writing</h1>
  <p class="page-lede">
    For other outlets, as well as notes on collective behavior, statistics, and
    technology.
  </p>

  <section class="section">
    <div class="section__head">
      <h2>Published elsewhere</h2>
    </div>
    <ul class="essay-list">
      {
        essays.map((essay) => {
          const d = essayDate(essay.date);
          return (
            <li class="essay-feature">
              <a
                class="essay-feature__link"
                href={essay.url}
                target="_blank"
                rel="noopener noreferrer"
              >
                <div class="essay-feature__media" aria-hidden="true">
                  {essay.image ? (
                    <img src={essay.image} alt="" class="essay-feature__img" />
                  ) : essay.logo ? (
                    <img src={essay.logo} alt="" class="essay-feature__logo" />
                  ) : (
                    <span class="essay-feature__mark">{outletMark(essay.outlet)}</span>
                  )}
                </div>
                <div class="essay-feature__body">
                  <p class="essay-feature__meta">
                    <span class="essay-feature__outlet">{essay.outlet}</span>
                    <span aria-hidden="true"> · </span>
                    <time datetime={dateAttr(d)}>
                      {formatDate(d, {
                        year: 'numeric',
                        month: 'short',
                        day: 'numeric',
                      })}
                    </time>
                  </p>
                  <h3 class="essay-feature__title">{essay.title}</h3>
                  <p class="essay-feature__blurb">{essay.blurb}</p>
                </div>
              </a>
            </li>
          );
        })
      }
    </ul>
  </section>

  <section class="section">
    <div class="section__head">
      <h2>Notes</h2>
    </div>
    <ul class="post-list">
      {
        posts.map((post) => (
          <li class="post-item">
            <p class="post-item__date">
              <time datetime={dateAttr(post.data.date)}>
                {formatDate(post.data.date, {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
            </p>
            <h3>
              <a href={`/blog/${post.id}/`}>{post.data.title}</a>
            </h3>
            <p class="mute">{post.data.description}</p>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
