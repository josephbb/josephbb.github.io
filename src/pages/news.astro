---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { formatDate, dateAttr } from '../lib/dates';

const news = (await getCollection('news')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title="News" description="Recent news and updates from Joe B. Bak-Coleman.">
  <h1 class="page-title">News</h1>
  <p class="page-lede">Talks, papers, appointments, and other notes of record.</p>

  <section class="section">
    <ul class="news-list">
      {
        news.map(async (item) => {
          const { Content } = await render(item);
          return (
            <li class="news-item">
              <time class="news-item__date" datetime={dateAttr(item.data.date)}>
                {item.data.date_label ?? formatDate(item.data.date)}
              </time>
              <div class="news-item__body">
                <Content />
              </div>
            </li>
          );
        })
      }
    </ul>
  </section>
</BaseLayout>
